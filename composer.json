{
    "name": "rzessack/symfony-health-monitor",
    "description": "System health monitoring bundle for Symfony — CPU, RAM, Disk, Load, DB, Redis with historical snapshots and Chart.js dashboard",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "health",
        "monitoring",
        "system",
        "cpu",
        "ram",
        "disk",
        "redis",
        "dashboard"
    ],
    "authors": [
        {
            "name": "Robert Zessack",
            "email": "mail@zerocom.gmbh"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/config": "^7.0 || ^8.0",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^2.10 || ^3.0",
        "symfony/console": "^7.0 || ^8.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/phpunit-bridge": "^7.0 || ^8.0"
    },
    "suggest": {
        "ext-redis": "For native Redis health checks instead of socket-based",
        "symfony/scheduler": "For scheduling snapshot collection via Symfony Scheduler"
    },
    "autoload": {
        "psr-4": {
            "Rzessack\\HealthMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rzessack\\HealthMonitor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "recipes": false
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
